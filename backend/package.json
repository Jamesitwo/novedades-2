{
  "name": "novedades-backend",
  "version": "1.0.0",
  "description": "API para gestión de novedades y pedidos en oficina",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "npx prisma generate --schema prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema prisma/schema.prisma",
    "db:push": "npx prisma db push --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
