# =============================================
# GestiónNovedades - Variables de Entorno (Desarrollo Local con PostgreSQL)
# Copiar a .env para desarrollo local con docker-compose.dev.yml
# =============================================

# --- Base de Datos (PostgreSQL local vía Docker) ---
DATABASE_URL="postgresql://novedades:novedades@localhost:5432/novedades?schema=public"

# --- JWT ---
JWT_SECRET="dev_secret_key_for_testing_only_change_in_production"
JWT_EXPIRES_IN="8h"

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- CORS ---
FRONTEND_URL="http://localhost:3000"
