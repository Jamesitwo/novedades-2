# =============================================
# GestiónNovedades - Variables de Entorno
# Copiar a .env y modificar según entorno
# =============================================

# --- Base de Datos ---
# Prisma schema está configurado para PostgreSQL en todos los entornos.
DATABASE_URL="postgresql://usuario:password@localhost:5432/novedades?schema=public"

# --- JWT ---
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio-min-32-caracteres"
JWT_EXPIRES_IN="8h"

# --- Servidor ---
PORT=3001
NODE_ENV=production

# --- CORS ---
FRONTEND_URL="http://localhost:3000"
