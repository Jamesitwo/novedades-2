# =============================================
# GestionNovedades - Variables de Entorno
# Copiar a .env y modificar segun entorno
# =============================================

# --- Base de Datos ---
# Prisma schema esta configurado para PostgreSQL en todos los entornos.
DATABASE_URL="postgresql://usuario:password@localhost:5432/novedades?schema=public"

# --- JWT ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio-min-32-caracteres"
JWT_EXPIRES_IN="8h"

# --- Servidor ---
PORT=3001
NODE_ENV=production

# --- CORS ---
# URL del frontend. Obligatorio en produccion.
FRONTEND_URL="http://localhost:3000"

# --- WhatsApp Cloud API (Meta) ---
# Obtener desde Meta Business Suite > WhatsApp > Configuracion
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# APP_SECRET: Obligatorio en produccion para verificar firma de webhooks.
# Obtener desde Meta Business Suite > WhatsApp > Configuracion > Webhook
WHATSAPP_APP_SECRET=
# VERIFY_TOKEN: Token arbitrario usado para verificacion inicial del webhook.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v22.0

# --- LucidSales ---
# Credenciales de la API de LucidSales (panel e-commerce)
LUCIDSALES_EMAIL=
LUCIDSALES_PASSWORD=
LUCIDSALES_SHOP_ID=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
